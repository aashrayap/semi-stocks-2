      "boundElements": null,
      "updated": 1776578400000,
      "link": null,
      "locked": false,
      "text": "Structural shifts\n\n1. Deal edges -> evidence projections\n\n2. One Cluster -> three lenses:\nThesis Cluster\nCompany Category\nSignal Cluster\n\n3. Transactions -> table modes:\nSignals\nClaims\nPositions\nSources\n\n4. Trace enabled -> Trace gated\n\n5. Split exports -> one signal_desk.json",
      "fontSize": 16,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Structural shifts\n\n1. Deal edges -> evidence projections\n\n2. One Cluster -> three lenses:\nThesis Cluster\nCompany Category\nSignal Cluster\n\n3. Transactions -> table modes:\nSignals\nClaims\nPositions\nSources\n\n4. Trace enabled -> Trace gated\n\n5. Split exports -> one signal_desk.json",
      "autoResize": false,
      "lineHeight": 1.18
    },
